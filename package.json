{
	"name": "vlp",
	"displayName": "Valdese Lakeside Park",
	"version": "5.1.0",
	"description": "Navigating the Valdese Lakeside Park",
	"scripts": {
		"refresh-baseline-browser-mapping": "pnpm i --save-dev baseline-browser-mapping@latest",
		"build-pmtiles": "node bin/build-pmtiles.mjs",
		"gen-leafletcss": "node bin/genLeafletCSS.js",
		"dev": "node bin/make-leaflet.mjs dev",
		"build": "node bin/make-leaflet.mjs",
		"serve": "http-server -p 1336 build -c-1 --gzip",
		"serve-pmtiles": "http-server -p 8080 ../pmtiles -c-1 --cors",
		"dev-maplibre": "node bin/make-maplibre.mjs dev",
		"make-maplibre": "node bin/make-maplibre.mjs",
		"make-mapburke-dev": "node bin/make-mapburke.mjs dev",
		"make-mapburke-remote": "node bin/make-mapburke.mjs remote",
		"make-mapburke": "node bin/make-mapburke.mjs",
		"optimize-svg": "pnpm svgo -f src/svg"
	},
	"author": "Valdese Network",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/valdese-net/vlp.git"
	},
	"dependencies": {
		"@mdi/js": "^7.4.47",
		"@turf/turf": "^7.3.4",
		"dayjs": "^1.11.19",
		"leaflet": "^1.9.4",
		"leaflet-ant-path": "^1.3.0",
		"leaflet.featuregroup.subgroup": "^1.0.2",
		"leaflet.markercluster": "^1.5.3",
		"leaflet.motion": "^0.3.2",
		"maplibre-gl": "^5.21.1",
		"navigo": "7.1.2",
		"pmtiles": "^4.4.0",
		"protomaps-leaflet": "^5.1.0",
		"workbox-window": "^7.4.0"
	},
	"devDependencies": {
		"@chialab/esbuild-plugin-html": "^0.19.0",
		"baseline-browser-mapping": "^2.9.19",
		"esbuild": "^0.27.3",
		"esbuild-sass-plugin": "^3.6.0",
		"gzipme": "^1.0.0",
		"http-server": "^14.1.1",
		"marked": "^17.0.1",
		"p-iteration": "^1.1.8",
		"sass": "^1.97.3",
		"sass-loader": "^16.0.7",
		"shpjs": "^6.2.0",
		"svgo": "^4.0.0",
		"twing": "^7.2.2",
		"unplugin-starter": "^0.1.0",
		"workbox": "^0.0.0",
		"workbox-build": "^7.4.0",
		"yaml": "^2.8.2"
	}
}
